# ═══════════════════════════════════════════════════════════
#  NEXOWORK — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to Git.
# ═══════════════════════════════════════════════════════════

# ── Firebase (required for Auth + Firestore + Storage) ───────
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123

# ── PostgreSQL (optional — for Express API) ──────────────────
# Get a free DB at: https://neon.tech or https://supabase.com
POSTGRES_URL=postgresql://user:password@host:5432/nexowork?sslmode=require

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://your-app.netlify.app
